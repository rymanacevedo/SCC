{
  "root": false,
  "extends": ["../../biome.json"],
  "files": {
    "includes": [
      "app/**/*.ts",
      "app/**/*.tsx",
      "app/**/*.js",
      "app/**/*.jsx",
      "app/**/*.css",
      "biome.json",
      "package.json",
      "tsconfig.json",
      "vite.config.ts",
      "!node_modules/**/*",
      "!docs/**/*",
      "!dist/**/*",
      "!public/**/*",
      "!bin/**/*"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noInferrableTypes": "off"
      },
      "a11y": {
        "noLabelWithoutControl": {
          "level": "error",
          "options": {
            "labelAttributes": ["label"],
            "labelComponents": ["Label"],
            "inputComponents": ["BaseAriaCheckbox"]
          }
        }
      }
    }
  },
  "css": {
    "formatter": {
      "quoteStyle": "single"
    }
  }
}
